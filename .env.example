# Copy to .env and fill in. The real host stays out of version control.
API_BASE_URL=https://your-simulator-host.example.com

# Optional overrides (defaults shown). Set them here locally, or as GitHub Actions
# repository variables in CI (they override .env at runtime; unset falls back to
# the code defaults in engine/constants/settings.py).
REQUEST_TIMEOUT=30
SETTLEMENT_TIMEOUT=30
SETTLEMENT_POLL_INTERVAL=1.5
